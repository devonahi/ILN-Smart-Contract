{
  "name": "@iln/cli",
  "version": "0.1.0",
  "description": "CLI for the Invoice Liquidity Network",
  "bin": {
    "iln": "./dist/index.js"
  },
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:cli-e2e": "jest --testPathPattern=tests/e2e",
    "lint": "eslint src"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^16.0.1",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.0.0",
    "execa": "^9.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts",
      "**/src/**/*.test.ts"
    ]
  }
}
